# Frontend Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration
REACT_APP_BACKEND_URL=https://your-api-domain.com

# Google AdMob (Get from https://admob.google.com)
REACT_APP_ADMOB_APP_ID=ca-app-pub-xxxxx~xxxxx
REACT_APP_ADMOB_BANNER_ID=ca-app-pub-xxxxx/xxxxx
REACT_APP_ADMOB_INTERSTITIAL_ID=ca-app-pub-xxxxx/xxxxx

# Analytics (Optional)
REACT_APP_GA_ID=G-XXXXXXXXXX
REACT_APP_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Feature Flags
REACT_APP_ENABLE_ADS=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_SOCIAL_SHARE=true

# Development
REACT_APP_ENV=development
REACT_APP_DEBUG=false

# WebSocket (If needed for future features)
REACT_APP_WS_URL=wss://your-ws-domain.com

# Stripe (For payments)
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_xxxxx

# Social Auth (Optional)
REACT_APP_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
REACT_APP_FACEBOOK_APP_ID=xxxxx